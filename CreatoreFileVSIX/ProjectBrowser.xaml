<platform:DialogWindow x:Class="CreatoreFileVSIX.ProjectBrowser"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:platform="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:shell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d" 
             Title="Select Target Folder / Project" Height="400" Width="400"
             WindowStartupLocation="CenterScreen"
             HasDialogFrame="False"
             WindowStyle="None"
             BorderThickness="0"
             BorderBrush="Transparent"
             AllowsTransparency="True"
             ResizeMode="NoResize"
             ShowInTaskbar="False">
             
    <platform:DialogWindow.Background>
        <DynamicResource ResourceKey="{x:Static platform:EnvironmentColors.ToolWindowBackgroundBrushKey}"/>
    </platform:DialogWindow.Background>
    <platform:DialogWindow.Foreground>
        <DynamicResource ResourceKey="{x:Static platform:EnvironmentColors.ToolWindowTextBrushKey}"/>
    </platform:DialogWindow.Foreground>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <TreeView x:Name="ProjectTreeView" Margin="5"
                  Background="Transparent" BorderThickness="1"
                  BorderBrush="{DynamicResource {x:Static platform:EnvironmentColors.ToolWindowBorderBrushKey}}"
                  Foreground="{DynamicResource {x:Static platform:EnvironmentColors.ToolWindowTextBrushKey}}"
                  ItemsSource="{Binding SolutionNodes}">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding Name}" Margin="0,2" />
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static platform:EnvironmentColors.ToolWindowTextBrushKey}}" />
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="1" Margin="5">
            <Button x:Name="ConfirmButton" Content="Select" Width="80" Margin="0,0,10,0" IsDefault="True" Click="ConfirmButton_Click" />
            <Button x:Name="CancelSelectionButton" Content="Cancel" Width="80" IsCancel="True" Click="CancelSelectionButton_Click" />
        </StackPanel>
    </Grid>
</platform:DialogWindow>
