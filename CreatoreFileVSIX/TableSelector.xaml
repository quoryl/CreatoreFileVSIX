<platform:DialogWindow x:Class="CreatoreFileVSIX.TableSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:platform="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:shell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d" 
             Title="Table Selector" Height="300" Width="450"
             WindowStartupLocation="CenterScreen"
             HasDialogFrame="False"
             WindowStyle="None"
             BorderThickness="0"
             BorderBrush="Transparent"
             AllowsTransparency="True"
             ResizeMode="NoResize"
             ShowInTaskbar="False">
             
    <platform:DialogWindow.Background>
        <DynamicResource ResourceKey="{x:Static platform:EnvironmentColors.ToolWindowBackgroundBrushKey}"/>
    </platform:DialogWindow.Background>
    <platform:DialogWindow.Foreground>
        <DynamicResource ResourceKey="{x:Static platform:EnvironmentColors.ToolWindowTextBrushKey}"/>
    </platform:DialogWindow.Foreground>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <TextBlock Text="Connection string:" Margin="5" />
        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ConnectionStringTextBox" Margin="0,0,5,0" />
            <Button x:Name="ConnectButton" Content="Connect" Width="75" Grid.Column="1" Click="ConnectButton_Click" />
        </Grid>

        <Button x:Name="ModeToggleButton" Content="Switch to Manual entry" Margin="5" Grid.Row="2" Click="ModeToggleButton_Click" />

        <StackPanel x:Name="ManualPanel" Grid.Row="3" Margin="5" Visibility="Collapsed">
            <TextBlock Text="Table name:" Margin="0,0,0,5" />
            <TextBox x:Name="ManualTableNameTextBox" TextChanged="TableName_TextChanged" />
        </StackPanel>

        <StackPanel x:Name="SelectionPanel" Grid.Row="4" Margin="5" Visibility="Visible">
            <TextBlock Text="Select a table:" Margin="0,0,0,5" />
            <ComboBox x:Name="TablesComboBox" SelectionChanged="TablesComboBox_SelectionChanged" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="6" Margin="5">
            <Button x:Name="NextButton" Content="Next" Width="80" Margin="0,0,10,0" IsDefault="True" Click="NextButton_Click" />
            <Button x:Name="CancelButton" Content="Cancel" Width="80" IsCancel="True" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</platform:DialogWindow>
