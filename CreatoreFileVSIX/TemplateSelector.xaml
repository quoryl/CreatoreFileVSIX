<platform:DialogWindow x:Class="CreatoreFileVSIX.TemplateSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:platform="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:shell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d" 
             Title="Template Selector" Height="500" Width="600"
             WindowStartupLocation="CenterScreen"
             HasDialogFrame="False"
             WindowStyle="None"
             BorderThickness="0"
             BorderBrush="Transparent"
             AllowsTransparency="True"
             ResizeMode="NoResize"
             ShowInTaskbar="False">
             
    <platform:DialogWindow.Background>
        <DynamicResource ResourceKey="{x:Static platform:EnvironmentColors.ToolWindowBackgroundBrushKey}"/>
    </platform:DialogWindow.Background>
    <platform:DialogWindow.Foreground>
        <DynamicResource ResourceKey="{x:Static platform:EnvironmentColors.ToolWindowTextBrushKey}"/>
    </platform:DialogWindow.Foreground>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Top Toolbar -->
        <StackPanel Orientation="Horizontal" Margin="5">
            <Button x:Name="AddButton" Content="Add" Width="80" Margin="0,0,10,0" Click="AddButton_Click" />
            <Button x:Name="ResetButton" Content="Reset" Width="80" Margin="0,0,10,0" Click="ResetButton_Click" />
            <Button x:Name="LoadDefaultButton" Content="Load Default" Width="100" Click="LoadDefaultButton_Click" />
        </StackPanel>
        
        <!-- List of Configuration Cards -->
        <ScrollViewer Grid.Row="1" Margin="5" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="CardsContainer">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="1" 
                                BorderBrush="{DynamicResource {x:Static platform:EnvironmentColors.ToolWindowBorderBrushKey}}" 
                                Margin="0,0,0,10" Padding="10">
                            
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Template Selection -->
                                <TextBlock Text="Select a template:" Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10"
                                          ItemsSource="{Binding DataContext.AvailableTemplates, RelativeSource={RelativeSource AncestorType=platform:DialogWindow}}"
                                          SelectedItem="{Binding SelectedTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <!-- Target Path Selection -->
                                <TextBlock Text="Select target path:" Grid.Row="1" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" />
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,10,10" IsReadOnly="True"
                                         Text="{Binding TargetPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Row="1" Grid.Column="2" Content="..." Width="30" Margin="0,0,0,10" 
                                        Command="{Binding DataContext.BrowsePathCommand, RelativeSource={RelativeSource AncestorType=platform:DialogWindow}}"
                                        CommandParameter="{Binding}" />

                                <!-- Subfolder Checkbox -->
                                <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,10"
                                          Content="Create subfolder before creating the file"
                                          IsChecked="{Binding CreateSubfolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <!-- Remove Button -->
                                <Button Grid.Row="3" Grid.Column="2" Content="Remove" Width="80" HorizontalAlignment="Right"
                                        Command="{Binding DataContext.RemoveCardCommand, RelativeSource={RelativeSource AncestorType=platform:DialogWindow}}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Bottom Action Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="2" Margin="5">
            <Button x:Name="NextButton" Content="Next" Width="80" Margin="0,0,10,0" IsDefault="True" Click="NextButton_Click" />
            <Button x:Name="CancelButton" Content="Cancel" Width="80" IsCancel="True" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</platform:DialogWindow>
